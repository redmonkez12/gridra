{
  "name": "@gridra/table-reference",
  "private": true,
  "description": "Private workspace-only reference table renderer for the gridra demo app.",
  "version": "0.1.0",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup --config tsup.config.ts && tsc -b tsconfig.json --force"
  },
  "dependencies": {
    "@gridra/react": "0.1.0",
    "@tanstack/react-virtual": "^3.13.12"
  },
  "peerDependencies": {
    "react": "^19.1.1",
    "react-dom": "^19.1.1"
  }
}
